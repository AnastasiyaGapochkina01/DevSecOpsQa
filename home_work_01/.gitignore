*.temp
*.cache
.cache/

# Test files
test/
tests/
*.test.yml
*.tests.yml

# Documentation build
docs/_build/
site/

# Local configuration
local.yml
local_inventory
custom_vars.yml

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini










