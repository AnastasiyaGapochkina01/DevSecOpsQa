*.egg
dist/
build/
.eggs/

# Ansible specific
*.retry
*.log
*.tmp
ansible.log
.ansible/
ansible.cfg (if it contains sensitive data)

# Inventory files that might contain sensitive data
inventory
inventory/*
!inventory.example
*.ini
hosts
hosts.yml
!hosts.example.yml

# Vault files
*.vault
*.vault.yml
.vault_pass
vault_pass.txt
vault_password

# Sensitive data
secrets.yml
*.secret
*.secrets
passwords.yml
credentials.yml
*.pem
*.key
*.crt
*.p12

# Role specific
roles/*/files/*.key
roles/*/files/*.pem
roles/*/vars/secrets.yml
roles/*/vars/vault.yml

# Collection files
collections/
~ansible_collections/

# Environment files
.env
.env.local
.venv/
venv/
env/
virtualenv/

